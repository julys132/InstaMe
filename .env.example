NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/instame

# Auth
SESSION_SECRET=change-this-secret

# Gemini (real image generation)
GEMINI_API_KEY=your-gemini-api-key
STYLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
STYLE_TEXT_MODEL=gemini-3-flash-preview

# Stripe (real payments)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Public URL (used for Stripe success/cancel redirects if needed)
PUBLIC_WEB_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
CORS_ALLOW_ALL=false
# Railway injects this automatically in production
RAILWAY_PUBLIC_DOMAIN=

# Optional OAuth audiences
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
APPLE_BUNDLE_ID=com.instame.app

# Optional in-app purchase config
GOOGLE_PLAY_PACKAGE_NAME=com.instame.app
IAP_PRODUCT_CREDITS={"com.instame.app.credits.5":5,"com.instame.app.credits.15":15,"com.instame.app.credits.30":30,"com.instame.app.credits.100":100}

# Credit tuning
DEFAULT_INITIAL_CREDITS=3
INSTAME_TRANSFORM_COST=5
