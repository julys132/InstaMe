NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/instame

# Auth
SESSION_SECRET=change-this-secret

# Gemini (real image generation)
GEMINI_API_KEY=your-gemini-api-key
STYLE_IMAGE_MODEL=gemini-3-pro-image-preview
STYLE_TEXT_MODEL=gemini-3-flash-preview
OWN_STYLE_ANALYSIS_MODEL=gemini-3-flash-preview
CREATIVE_OWN_STYLE_ANALYSIS_MODEL=gemini-3.1-pro
INSTAME_DEBUG_TRACE=false
INSTAME_DEBUG_TRACE_EMAILS=iuliastarcean@gmail.com

# OpenAI / Together / Reve (real image generation + editing)
OPENAI_API_KEY=
TOGETHER_API_KEY=
REVE_API_KEY=
REVE_API_BASE_URL=https://api.reve.com
REVE_EDIT_VERSION_REVE_V1_1_PREVIEW=latest-fast
REVE_EDIT_VERSION_REVE_V1_1_HIGH_RES=latest

# Stripe (real payments)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Public URL (used for Stripe success/cancel redirects if needed)
PUBLIC_WEB_URL=http://localhost:5000
PUBLIC_APP_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
CORS_ALLOW_ALL=false
# Railway injects this automatically in production
RAILWAY_PUBLIC_DOMAIN=

# Optional OAuth audiences
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
APPLE_BUNDLE_ID=com.instame.app
APPLE_SHARED_SECRET=
APPLE_SERVER_NOTIFICATION_ROOT_CERT_URL=https://www.apple.com/certificateauthority/AppleRootCA-G3.cer

# Optional in-app purchase config
GOOGLE_PLAY_PACKAGE_NAME=com.instame.app
IAP_PRODUCT_CREDITS={"com.instame.app.credits.quickstart10":10,"com.instame.app.credits.creator30":30,"com.instame.app.credits.studio60":60,"com.instame.app.credits.bestvalue200":200}
EXPO_PUBLIC_IOS_IAP_SUBSCRIPTION_MAP={"sub_basic":"com.instame.app.sub.lite.monthly","sub_premium":"com.instame.app.sub.plus.monthly","sub_unlimited":"com.instame.app.sub.studio.monthly"}
APPLE_IAP_SUBSCRIPTION_PRODUCT_MAP={"com.instame.app.sub.lite.monthly":"sub_basic","com.instame.app.sub.plus.monthly":"sub_premium","com.instame.app.sub.studio.monthly":"sub_unlimited"}
EXPO_PUBLIC_ENABLE_WEB_STRIPE_CHECKOUT=false

# Credit tuning
DEFAULT_INITIAL_CREDITS=3
INSTAME_TRANSFORM_COST=5

# Optional Railway Bucket for large InstaMe style preview assets
# These can use Railway variable references from a Bucket service:
# INSTAME_STYLE_ASSETS_BUCKET_NAME=${{Bucket.BUCKET}}
# INSTAME_STYLE_ASSETS_BUCKET_ENDPOINT=${{Bucket.ENDPOINT}}
# INSTAME_STYLE_ASSETS_BUCKET_REGION=${{Bucket.REGION}}
# INSTAME_STYLE_ASSETS_BUCKET_ACCESS_KEY_ID=${{Bucket.ACCESS_KEY_ID}}
# INSTAME_STYLE_ASSETS_BUCKET_SECRET_ACCESS_KEY=${{Bucket.SECRET_ACCESS_KEY}}
INSTAME_STYLE_ASSETS_BUCKET_NAME=
INSTAME_STYLE_ASSETS_BUCKET_ENDPOINT=
INSTAME_STYLE_ASSETS_BUCKET_REGION=auto
INSTAME_STYLE_ASSETS_BUCKET_ACCESS_KEY_ID=
INSTAME_STYLE_ASSETS_BUCKET_SECRET_ACCESS_KEY=
INSTAME_STYLE_ASSETS_BUCKET_FORCE_PATH_STYLE=false
